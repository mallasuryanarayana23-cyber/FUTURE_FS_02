# =========================================================================
# NexusCRM - Configuration Environment Template
# =========================================================================
# Rename this file to '.env' and place it in the '/server' directory.

# Express Node Server Port
PORT=5000

# MongoDB Connection String (Local instance or MongoDB Atlas URL)
MONGO_URI=mongodb://localhost:27017/crm_db

# Secret key utilized for signing JWT Web Tokens (use a long random alphanumeric string)
JWT_SECRET=your_super_secret_jwt_key_123

# Node Environment settings
NODE_ENV=development
